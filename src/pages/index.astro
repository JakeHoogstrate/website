---
import Layout from '../layouts/Layout.astro';
import Icon from '../components/Icon.astro';

export const prerender = true;

const contacts = [
	{ label: 'jakehoogstrate5@gmail.com', href: 'mailto:jakehoogstrate5@gmail.com', icon: 'mail' },
	{ label: '(551) 237-4814', href: 'tel:+15512374814', icon: 'phone' },
	{ label: 'JakeHoogstrate', href: 'https://github.com/JakeHoogstrate', icon: 'github' },
	{ label: 'jacob-hoogstrate', href: 'https://www.linkedin.com/in/jacob-hoogstrate-2478292a4/', icon: 'linkedin' },
] as const;
---

<Layout title="About">
	<section class="mb-16">
		<h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 mb-6">About Me</h1>
		<p class="text-lg text-slate-600 leading-relaxed max-w-2xl mb-8">
			I'm a computer science student who likes building things, I'm currently interning as a
			software engineer at Berlin AI Solutions, and outside of that I'm an Eagle Scout who is
			passionate about the outdoors. When I'm not coding, you'll usually find me analyzing the
			Mets. Check out my coding projects and Mets blog. Feel free to contact me for any personal
			or business inquiries.
		</p>
		<div class="flex flex-wrap gap-3">
			<a
				href="/projects"
				class="inline-flex items-center rounded-full bg-gradient-to-r from-indigo-600 to-fuchsia-600 px-5 py-2.5 text-sm font-medium text-white shadow-md shadow-indigo-200 hover:shadow-lg hover:shadow-indigo-300 transition-shadow"
			>
				View my projects
			</a>
			<a
				href="/blog"
				class="inline-flex items-center rounded-full border border-slate-300 px-5 py-2.5 text-sm font-medium text-slate-700 hover:border-indigo-600 hover:text-indigo-600 transition-colors"
			>
				Read the blog
			</a>
		</div>
	</section>

	<section>
		<h2 class="text-xl font-semibold tracking-tight text-slate-900 mb-5">Get in touch</h2>
		<ul class="grid sm:grid-cols-2 gap-3">
			{contacts.map((contact) => (
				<li>
					<a
						href={contact.href}
						class="flex items-center gap-3 rounded-lg border border-slate-200 px-4 py-3 text-slate-600 hover:border-indigo-300 hover:text-indigo-600 hover:bg-indigo-50/50 transition-colors"
					>
						<Icon name={contact.icon} class="w-5 h-5 shrink-0" />
						<span class="text-sm">{contact.label}</span>
					</a>
				</li>
			))}
		</ul>
	</section>
</Layout>
