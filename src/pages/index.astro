---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About">
	<h1 class="text-3xl font-bold tracking-tight mb-4">Hi, I'm Jake.</h1>
	<p class="text-slate-600 leading-relaxed mb-4">
		Welcome to my corner of the internet. Replace this paragraph with a short bio:
		who you are, what you work on, and what you're interested in.
	</p>
	<p class="text-slate-600 leading-relaxed">
		Check out my <a href="/projects" class="text-slate-900 underline underline-offset-2">projects</a>,
		read the <a href="/blog" class="text-slate-900 underline underline-offset-2">blog</a>, or
		<a href="/contact" class="text-slate-900 underline underline-offset-2">get in touch</a>.
	</p>
</Layout>
