---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Blog">
	<h1 class="text-3xl font-bold tracking-tight mb-8">Blog</h1>
	{posts.length === 0 && <p class="text-slate-600">No posts yet — check back soon.</p>}
	<ul class="space-y-8">
		{posts.map((post) => (
			<li>
				<a href={`/blog/${post.id}`} class="text-lg font-semibold text-slate-900 hover:underline underline-offset-2">
					{post.data.title}
				</a>
				<p class="text-sm text-slate-400 mt-1">
					{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
				</p>
				<p class="text-slate-600 mt-1">{post.data.description}</p>
			</li>
		))}
	</ul>
</Layout>
