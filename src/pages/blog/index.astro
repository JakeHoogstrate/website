---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Blog">
	<h1 class="text-3xl font-bold tracking-tight mb-2 bg-gradient-to-r from-mets-blue to-mets-orange bg-clip-text text-transparent">
		Mets Blog
	</h1>
	<p class="text-slate-600 mb-10">Using data driven analysis to talk Mets baseball.</p>
	{posts.length === 0 && <p class="text-slate-600">No posts yet — check back soon.</p>}
	<ul class="space-y-4">
		{posts.map((post) => (
			<li>
				<a
					href={`/blog/${post.id}`}
					class="group block rounded-xl border border-slate-200 p-6 transition-all hover:border-mets-orange/50 hover:shadow-lg hover:shadow-orange-100"
				>
					<p class="text-sm text-slate-400 mb-1">
						{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
					</p>
					<h2 class="text-lg font-semibold text-slate-900 group-hover:text-mets-blue transition-colors">{post.data.title}</h2>
					<p class="text-slate-600 mt-2 text-sm leading-relaxed">{post.data.description}</p>
				</a>
			</li>
		))}
	</ul>
</Layout>
