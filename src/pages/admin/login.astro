---
import Layout from '../../layouts/Layout.astro';
import Icon from '../../components/Icon.astro';

export const prerender = false;

const error = Astro.url.searchParams.get('error') === '1';
---

<Layout title="Admin Login">
	<div class="max-w-sm mx-auto mt-12">
		<div class="rounded-xl border border-slate-200 p-8">
			<div class="flex items-center justify-center w-12 h-12 rounded-full bg-indigo-50 text-indigo-600 mx-auto mb-6">
				<Icon name="lock" class="w-6 h-6" />
			</div>
			<h1 class="text-xl font-semibold tracking-tight text-slate-900 text-center mb-6">Admin Login</h1>
			{
				error && (
					<p class="text-sm text-red-600 bg-red-50 border border-red-200 rounded-lg px-3 py-2 mb-4">
						Incorrect password. Try again.
					</p>
				)
			}
			<form method="POST" action="/api/login" class="space-y-4">
				<input
					type="password"
					name="password"
					required
					autofocus
					placeholder="Password"
					class="w-full rounded-lg border border-slate-300 px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent"
				/>
				<button
					type="submit"
					class="w-full rounded-full bg-slate-900 px-5 py-2.5 text-sm font-medium text-white hover:bg-indigo-600 transition-colors"
				>
					Log in
				</button>
			</form>
		</div>
	</div>
</Layout>
