---

{
	solid[name] && (
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class={className} aria-hidden="true">
			<path d={solid[name]} />
		</svg>
	)
}
{
	outline[name] && (
		<svg
			xmlns="http://www.w3.org/2000/svg"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="1.5"
			stroke-linecap="round"
			stroke-linejoin="round"
			class={className}
			aria-hidden="true"
		>
			<path d={outline[name]} />
		</svg>
	)
}
